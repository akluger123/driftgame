<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Drift Hunters: Modular Edition</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.4.0/p5.js"></script>
    <style>
        /* SECTION 1: VISUAL STYLES (CSS) */
        body { margin: 0; padding: 0; display: flex; justify-content: center; align-items: center; height: 100vh; background-color: #1a1a1a; color: white; font-family: 'Arial', sans-serif; overflow: hidden; }
        canvas { border: 4px solid #444; box-shadow: 0 0 20px rgba(0,0,0,0.5); }
        .ui-panel { position: absolute; background: rgba(0,0,0,0.9); padding: 20px; border-radius: 10px; border: 2px solid #00ff00; text-align: center; z-index: 100; }
        input { display: block; width: 80%; margin: 10px auto; padding: 10px; background: #222; border: 1px solid #0f0; color: #0f0; }
        .button { background: linear-gradient(135deg, #00ff00, #00cc00); color: #000; border: none; padding: 12px 30px; margin: 10px; border-radius: 5px; cursor: pointer; font-size: 16px; font-weight: bold; }
        #hud { position: absolute; top: 20px; left: 20px; pointer-events: none; }
        .money-text { color: #00ff00; font-size: 24px; font-weight: bold; }
    </style>
</head>
<body>

<div id="login-menu" class="ui-panel">
    <h1 style="color:#0f0">DRIFT LOGIN</h1>
    <input type="text" id="user" placeholder="Username">
    <input type="password" id="pass" placeholder="Password">
    <button class="button" onclick="handleLogin()">START ENGINE</button>
</div>

<div id="hud" style="display:none">
    <div class="money-text" id="money-val">$0</div>
    <div style="font-size:12px">P: MENU | WASD: DRIFT</div>
</div>

<script>
// ==========================================
// SECTION 4: GLOBAL VARIABLES & CONFIG
// ==========================================
const GAME_STATE = { MENU: 'menu', PLAYING: 'playing', SHOP: 'shop' };
let state = GAME_STATE.MENU;
let car, currentCar = 'Red Pro', money = 0;
let unlockedCars = ['Red Pro'];
let camX = 0, camY = 0;
let trackPoints = [];
let obstacles = [];
let skidMarks = [];

const CAR_DATA = {
    'Red Pro': { color: [200, 30, 30], speed: 0.35, drift: 0.82, price: 0, isGTR: false },
    'Nissan GT-R': { color: [160, 160, 160], speed: 0.45, drift: 0.78, price: 500, isGTR: true }
};

// ==========================================
// SECTION 5: LOGIN & CORE LOGIC
// ==========================================
function setup() {
    createCanvas(1000, 600);
    noLoop();
